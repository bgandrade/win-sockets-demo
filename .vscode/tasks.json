{
  "tasks": [
    {
      "type": "shell",
      "label": "make active target",
      "command": "mingw32-make",
      "args": [
        "${fileBasenameNoExtension}"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": ["$gcc"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "detail": "Compila o alvo do arquivo ativo e gera a saída em build/"
    },
    {
      "type": "shell",
      "label": "make all",
      "command": "mingw32-make",
      "args": [
        "all"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": ["$gcc"],
      "detail": "Compila todos os executáveis em build/"
    },
    {
      "type": "shell",
      "label": "make clean",
      "command": "mingw32-make",
      "args": [
        "clean"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "detail": "Remove a pasta build e todos os artefatos gerados"
    }
  ],
  "version": "2.0.0"
}
